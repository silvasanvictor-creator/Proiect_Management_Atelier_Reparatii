@page
@model Management_Atelier_Reparatii.Pages.ComenziService.IndexModel
@using Management_Atelier_Reparatii.Models

@{
    ViewData["Title"] = "Index";
}


@* Only allow creating comenzi to Admins and Mechanics *@
@if (User.IsInRole("Admin") || User.IsInRole("Mecanic"))
{
    <p>
        <a asp-page="Create">Create New</a>
    </p>
}
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.ComandaService[0].Masina)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.ComandaService[0].Mecanic)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.ComandaService[0].DataPrimire)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.ComandaService[0].Status)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.ComandaService[0].Observatii)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model.ComandaService) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.Masina.NumarInmatriculare)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Mecanic.Nume)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.DataPrimire)
            </td>
            <td>
                    @if (item.Status == StatusComanda.Nou)
                    {
                        <span class="badge bg-secondary">Noua</span>
                    }
                    else if (item.Status == StatusComanda.InLucru)
                    {
                        <span class="badge bg-warning text-dark">In lucru</span>
                    }
                    else if (item.Status == StatusComanda.Finalizat)
                    {
                        <span class="badge bg-success">Finalizata</span>
                    }
                    else if (item.Status == StatusComanda.Predat)
                    {
                        <span class="badge bg-primary">Predată</span>
                    }
                </td>
            <td>
                @Html.DisplayFor(modelItem => item.Observatii)
            </td>
            <td>
                @if (User.IsInRole("Admin"))
                {
                    <a asp-page="./Edit" asp-route-id="@item.ComandaServiceId">Edit</a>
                    <a asp-page="./Details" asp-route-id="@item.ComandaServiceId">Details</a>
                    <a asp-page="./Delete" asp-route-id="@item.ComandaServiceId">Delete</a>

                    @* Inline server form to change status. Posts back to OnPostChangeStatusAsync *@
                    <form method="post" asp-page-handler="ChangeStatus" asp-route-id="@item.ComandaServiceId" class="d-inline">
                        <select name="newStatus" class="form-select form-select-sm d-inline w-auto">
                            <option value="" disabled>Selecteaza status comanda</option>
                            <option value="0" selected="@(item.Status == StatusComanda.Nou)">Noua</option>
                            <option value="1" selected="@(item.Status == StatusComanda.InLucru)">In lucru</option>
                            <option value="2" selected="@(item.Status == StatusComanda.Finalizat)">Finalizata</option>
                            <option value="3" selected="@(item.Status == StatusComanda.Predat)">Predată</option>
                        </select>
                        <button type="submit" class="btn btn-sm btn-primary ms-1">Update</button>
                    </form>
                }
                else if (User.IsInRole("Mecanic"))
                {
                    // Mecanic can edit, view details, and change status but not delete
                    <a asp-page="./Edit" asp-route-id="@item.ComandaServiceId">Edit</a>
                    <a asp-page="./Details" asp-route-id="@item.ComandaServiceId">Details</a>

                    @* Inline server form to change status for Mecanic as well *@
                    <form method="post" asp-page-handler="ChangeStatus" asp-route-id="@item.ComandaServiceId" class="d-inline">
                        <select name="newStatus" class="form-select form-select-sm d-inline w-auto">
                            <option value="" disabled>Selecteaza status comanda</option>
                            <option value="0" selected="@(item.Status == StatusComanda.Nou)">Noua</option>
                            <option value="1" selected="@(item.Status == StatusComanda.InLucru)">In lucru</option>
                            <option value="2" selected="@(item.Status == StatusComanda.Finalizat)">Finalizata</option>
                            <option value="3" selected="@(item.Status == StatusComanda.Predat)">Predată</option>
                        </select>
                        <button type="submit" class="btn btn-sm btn-primary ms-1">Update</button>
                    </form>
                }
            </td>
        </tr>
}
    </tbody>
</table>
